# ==========================================
# EStateMind AI - Master GitIgnore File
# ==========================================

# --- System Files ---
.DS_Store
Thumbs.db
*.log

# --- Backend (Python / FastAPI) ---
backend/venv/
backend/.venv/
backend/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
backend/.pytest_cache/
backend/tmp*/

# --- Frontend (Node / React / Vite) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.eslintcache

# --- Sensitive Environment Secrets (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
frontend/.env.local

# --- IDEs and Editors ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp